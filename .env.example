#----------------------------------------------------------
# Supabase (client-side — must be NEXT_PUBLIC_* to be exposed to the browser)
#   Local dev: run `supabase start` and copy the API URL + publishable/anon key.
#   Production: also add your prod URL + `<prod>/auth/callback` to the hosted
#   Supabase project's Auth redirect allow-list (and config.toml site_url).
#----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

#----------------------------------------------------------
# Google OAuth — consumed by supabase/config.toml via env() substitution.
#   Get these from https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://127.0.0.1:54321/auth/v1/callback
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
